@inherits LayoutComponentBase
@inject LanguageService LangSvc

<div class="min-h-screen pb-20 md:pb-0">
    <header class="sticky top-0 bg-slate-50/90 backdrop-blur-sm z-40 px-6 py-4 max-w-7xl mx-auto w-full">
        <div class="flex items-center justify-between gap-6">
            <a href="/" class="flex items-center gap-3">
                <img src="/icons/icon64x64.png" alt="KiddoGame" class="w-10 h-10 rounded-xl" />
                <div>
                    <span class="text-2xl font-bold bg-gradient-to-r from-indigo-500 to-purple-500 bg-clip-text text-transparent">
                        KiddoGame
                    </span>
                    <p class="text-slate-400 text-sm font-light"><SiteTagline /></p>
                </div>
            </a>

            <div class="flex items-center gap-4">
                <TopNav />
                <LanguageSwitcher />
            </div>
        </div>
    </header>

    <main class="max-w-7xl mx-auto px-6 py-4">
        @Body
    </main>
</div>

<MobileNav />

