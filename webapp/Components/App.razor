<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="/" />
    <link rel="shortcut icon" href="/favicon.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/icons/icon16x16.png" />
    <link rel="icon" type="image/png" sizes="32x32" href="/icons/icon32x32.png" />
    <link rel="icon" type="image/png" sizes="64x64" href="/icons/icon64x64.png" />
    <link rel="apple-touch-icon" href="/icons/icon256x256.png" />
    <link href="https://fonts.googleapis.com/css2?family=Kanit:wght@300;400;600&display=swap" rel="stylesheet" />
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        body { font-family: 'Kanit', sans-serif; -webkit-tap-highlight-color: transparent; }
        .hide-scrollbar::-webkit-scrollbar { display: none; }
        .hide-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
        .game-card:active { transform: scale(0.95); }
        .category-pill.active { background-color: #4F46E5; color: white; }
        /* Hide ALL Blazor reconnect states — show, failed, rejected */
        #components-reconnect-modal,
        #components-reconnect-modal.components-reconnect-show,
        #components-reconnect-modal.components-reconnect-failed,
        #components-reconnect-modal.components-reconnect-rejected {
            display: none !important;
            visibility: hidden !important;
            opacity: 0 !important;
            pointer-events: none !important;
        }
    </style>

    <link href="_content/Blazor.Flags/flags.css" rel="stylesheet" />
    <HeadOutlet />

    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-E9TSFWCCYV"></script>
    <script>
        window.dataLayer = window.dataLayer || [];
        function gtag(){dataLayer.push(arguments);}
        gtag('js', new Date());
        gtag('config', 'G-E9TSFWCCYV');
    </script>
</head>
<body class="bg-slate-50 text-slate-800">
    <Routes />
    <script src="_framework/blazor.web.js"></script>
    <script>
        // Must run AFTER blazor.web.js so the modal element exists
        (function () {
            var reloading = false;
            var observer = new MutationObserver(function (_, obs) {
                if (reloading) return;
                var modal = document.getElementById('components-reconnect-modal');
                if (!modal) return;
                var cls = modal.className;
                if (cls.includes('components-reconnect-show') ||
                    cls.includes('components-reconnect-failed') ||
                    cls.includes('components-reconnect-rejected')) {
                    reloading = true;
                    obs.disconnect();
                    // 2s delay gives server time to restart before we reload
                    setTimeout(function () { window.location.reload(); }, 2000);
                }
            });
            // Poll every 300ms until Blazor creates the modal, then attach observer
            var poll = setInterval(function () {
                var modal = document.getElementById('components-reconnect-modal');
                if (modal) {
                    clearInterval(poll);
                    observer.observe(modal, { attributes: true, attributeFilter: ['class'] });
                }
            }, 300);

            // On wake from sleep the MutationObserver may have missed the disconnect —
            // check reconnect state 2s after the tab becomes visible again.
            document.addEventListener('visibilitychange', function () {
                if (document.hidden || reloading) return;
                setTimeout(function () {
                    if (reloading) return;
                    var modal = document.getElementById('components-reconnect-modal');
                    if (!modal) return;
                    var cls = modal.className;
                    if (cls.includes('components-reconnect-show') ||
                        cls.includes('components-reconnect-failed') ||
                        cls.includes('components-reconnect-rejected')) {
                        reloading = true;
                        window.location.reload();
                    }
                }, 2000);
            });
        })();

        // Fullscreen helper — called from GamePage
        function enterFullscreen() {
            var iframe = document.getElementById('game-iframe');
            if (!iframe) return;
            var req = iframe.requestFullscreen || iframe.webkitRequestFullscreen ||
                      iframe.mozRequestFullScreen || iframe.msRequestFullscreen;
            if (req) req.call(iframe);
        }
    </script>
    <script>
        window.getLang = function () {
            var match = document.cookie.match(/(?:^|;\s*)lang=([^;]*)/);
            if (match) return match[1];
            var stored = localStorage.getItem("lang");
            if (stored) return stored;
            return navigator.language.startsWith("th") ? "th" : "en";
        };
        window.setLang = function (lang) {
            localStorage.setItem("lang", lang);
            document.cookie = "lang=" + lang + "; path=/; max-age=31536000; SameSite=Lax";
        };
    </script>
</body>
</html>
